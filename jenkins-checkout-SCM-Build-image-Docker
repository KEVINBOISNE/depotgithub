pipeline {
    agent any
       stages {
        stage('Nettoyer dossier workspace') {
           steps {
                cleanWs()
        }
    }
        stage('Cloner le Github') {
            steps {
                    git branch: 'main', url: 'https://github.com/KEVINBOISNE/depotgithub.git'
            }
        }

        stage('Install Docker') {
            steps {
                sh 'sudo apt purge docker* -y'
                sh 'sudo apt-get autoremove docker.io'
                sh 'sudo apt-get update -y'
                sh 'sudo apt-get install apt-transport-https ca-certificates curl software-properties-common -y'
                sh 'sudo apt-get install -y docker.io -y'
                sh 'sudo apt-get update -y'
                // sh 'sudo systemctl start docker'
                sh 'sudo chmod 666 /var/run/docker.sock'
                sh 'sudo usermod -aG docker $USER'
                sh 'sudo systemctl restart docker.service'
            }
        }

        stage('build image docker') {
            steps {
                //sh 'sudo docker image rm -f "myapp-image:latest"'
                sh 'sudo docker build -t "myapp-image"'
                sh 'sudo docker image ls'
            }
        }
        stage('create conteneur ngnix') {
            steps {
                //sh 'sudo docker rm -f myappcont'
                sh 'sudo docker run -d --name myappcont --hostname myappcont myapp-image:latest'
                sh 'sudo docker ps'
            }
        }
    }
}
